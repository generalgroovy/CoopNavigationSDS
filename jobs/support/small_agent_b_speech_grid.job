{
  "schema_version": 1,
  "name": "tinyllama_speech_performance_range",
  "description": "TinyLlama-to-TinyLlama baseline crossing preregistered floor-to-ceiling speech treatments with matched text controls.",
  "coverage_strategy": "full_factorial",
  "iterations": 1,
  "config": {
    "agent_a_type": "tinyllama",
    "agent_b_plugin": "llm",
    "model_profile": "tinyllama_1b_transformers",
    "model_provider": "transformers",
    "model_name": "TinyLlama/TinyLlama-1.1B-Chat-v1.0",
    "model_max_new_tokens": 24,
    "num_turns": 20,
    "maximum_progressive_constraints": 3,
    "minimum_compared_routes": 2,
    "paired_audio_text_runs": true,
    "speech_playback_enabled": false,
    "speech_realtime_enabled": false,
    "tts_engine": "piper",
    "tts_model": ".speech-providers/models/piper/en_US-lessac-medium.onnx",
    "asr_engine": "vosk",
    "asr_model": ".speech-providers/models/vosk/vosk-model-small-en-us-0.15",
    "log_profile": "full",
    "result_group": "agent_b/support/00-small-tinyllama/tinyllama"
  },
  "grid": {
    "test_cases": ["morning_peak_cross_city"],
    "personas": ["focused_commuter"],
    "agent_a_audio_personas": ["high_clarity_caller"],
    "agent_b_audio_personas": ["high_clarity_operator"],
    "speech_patterns": ["clean"],
    "model_params": ["greedy"],
    "objective_modes": ["shortest_valid_route_with_constraints"],
    "agent_b_models": ["TinyLlama/TinyLlama-1.1B-Chat-v1.0"],
    "tts_engines": ["piper"],
    "asr_engines": ["vosk"]
  },
  "speech_performance_bands": ["ceiling", "nominal", "challenging", "floor"],
  "parameter_values": {
    "matrix_family": ["tinyllama_speech_performance_v2"],
    "agent_b_llm_size": ["small"],
    "agent_b_model_role": ["support_baseline"],
    "network_seed": [42]
  }
}
