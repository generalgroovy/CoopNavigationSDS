{
  "schema_version": 1,
  "name": "linux_agent_a_tinyllama_speech_llm_matrix",
  "description": "Linux paired speech matrix using the staged TinyLlama-compatible caller and local Ollama models.",
  "iterations": 1,
  "config": {
    "agent_a_type": "tinyllama",
    "agent_b_plugin": "llm",
    "model_provider": "ollama",
    "model_base_url": "http://127.0.0.1:11434/api",
    "model_timeout_sec": 180,
    "paired_audio_text_runs": true,
    "speech_playback_enabled": false,
    "speech_realtime_enabled": false,
    "asr_end_silence_ms": 2500,
    "asr_ambiguous_end_silence_ms": 4500
  },
  "grid": {
    "test_cases": ["morning_peak_cross_city", "midday_transfer"],
    "personas": ["focused_commuter"],
    "agent_a_audio_personas": ["high_clarity_caller"],
    "agent_b_audio_personas": ["high_clarity_operator"],
    "speech_patterns": ["clean"],
    "model_params": ["greedy"],
    "objective_modes": ["shortest_valid_route_with_constraints"],
    "tts_engines": ["chattts", "piper", "espeak_ng", "coqui"],
    "asr_engines": ["faster_whisper", "vosk", "whisper_cpp", "sherpa_onnx"],
    "agent_b_models": ["llama3.2:3b", "phi3:mini", "qwen2.5:7b", "llama3.1:8b"]
  }
}
