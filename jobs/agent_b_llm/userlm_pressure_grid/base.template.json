{
  "schema_version": 1,
  "extends": "../../support/small_agent_b_speech_grid_userlm.job",
  "name": "userlm_pressure_grid_base",
  "description": "UserLM caller pressure grid for increasing semi-successful and unsuccessful route-dialogue cases without changing model-only comparisons. The linked pressure profiles implement ceiling control, semi-success amplification, constraint pressure, ASR degradation, audio-persona degradation, and turn-budget pressure.",
  "coverage_strategy": "pairwise",
  "iterations": 1,
  "config": {
    "agent_a_type": "userlm",
    "agent_b_plugin": "llm",
    "model_provider": "transformers",
    "model_base_url": "",
    "allow_model_download": false,
    "model_timeout_sec": 300,
    "model_max_new_tokens": 48,
    "num_turns": 20,
    "maximum_progressive_constraints": 3,
    "minimum_compared_routes": 3,
    "minimum_stage_suboptimal_options": 2,
    "require_stage_suboptimal_options": true,
    "require_constraint_retention": true,
    "acceptable_duration_ratio": 1.5,
    "paired_audio_text_runs": true,
    "speech_playback_enabled": false,
    "speech_realtime_enabled": false,
    "tts_engine": "piper",
    "tts_model": ".speech-providers/models/piper/en_US-lessac-medium.onnx",
    "asr_engine": "faster_whisper",
    "asr_model": ".speech-providers/models/faster-whisper",
    "log_profile": "full",
    "result_group": "agent_b/userlm_pressure/00-base/userlm"
  },
  "grid": {
    "test_cases": [
      "morning_peak_cross_city",
      "midday_transfer",
      "airport_connection",
      "crowded_event_exit",
      "late_event",
      "hospital_appointment",
      "multi_destination_errands"
    ],
    "personas": [
      "focused_commuter",
      "crowd_averse_rider",
      "delay_sensitive_traveler",
      "risk_averse_novice",
      "accessibility_rider",
      "multi_stop_errand_runner"
    ],
    "agent_a_audio_personas": ["high_clarity_caller"],
    "agent_b_audio_personas": ["high_clarity_operator"],
    "speech_patterns": ["clean"],
    "model_params": ["greedy", "temp0.7"],
    "objective_modes": ["shortest_valid_route_with_constraints"],
    "agent_b_models": ["configured-by-child-job"],
    "tts_engines": ["piper"],
    "asr_engines": ["faster_whisper"]
  },
  "speech_performance_bands": [],
  "linked_profiles": {
    "pipeline_pressure": [
      {
        "pipeline_pressure_profile_key": "ceiling_control",
        "profile_key": "P0-ceiling-control",
        "pressure_strategy": "ceiling_control",
        "expected_outcome_band": "successful",
        "agent_a_audio_persona": "high_clarity_caller",
        "agent_b_audio_persona": "high_clarity_operator",
        "speech_pattern_key": "clean",
        "asr_beam_size": 16,
        "asr_domain_normalization_enabled": true,
        "asr_domain_similarity_threshold": 0.8,
        "channel_noise_snr_db": null,
        "channel_gain_db": 0.0,
        "channel_clip_threshold": 1.0,
        "channel_dropout_rate": 0.0,
        "num_turns": 20,
        "dialogue_stagnation_limit": 3,
        "transfer_tolerance": 2,
        "max_turn_elapsed_sec": 8.0
      },
      {
        "pipeline_pressure_profile_key": "semi_success_amplifier",
        "profile_key": "P1-semi-success",
        "pressure_strategy": "semi_success_amplifier",
        "expected_outcome_band": "semi_successful",
        "agent_a_audio_persona": "neutral_caller",
        "agent_b_audio_persona": "clear_operator",
        "speech_pattern_key": "mostly_clean",
        "asr_beam_size": 3,
        "asr_domain_normalization_enabled": true,
        "asr_domain_similarity_threshold": 0.9,
        "channel_noise_snr_db": 22.0,
        "channel_gain_db": -3.0,
        "channel_clip_threshold": 0.9,
        "channel_dropout_rate": 0.01,
        "num_turns": 16,
        "dialogue_stagnation_limit": 2,
        "transfer_tolerance": 1,
        "max_turn_elapsed_sec": 6.0
      },
      {
        "pipeline_pressure_profile_key": "constraint_pressure",
        "profile_key": "P2-constraint-pressure",
        "pressure_strategy": "constraint_pressure",
        "expected_outcome_band": "semi_successful_or_unsuccessful",
        "agent_a_audio_persona": "hesitant_caller",
        "agent_b_audio_persona": "clear_operator",
        "speech_pattern_key": "hesitant",
        "asr_beam_size": 6,
        "asr_domain_normalization_enabled": true,
        "asr_domain_similarity_threshold": 0.92,
        "channel_noise_snr_db": 18.0,
        "channel_gain_db": -4.0,
        "channel_clip_threshold": 0.78,
        "channel_dropout_rate": 0.025,
        "num_turns": 14,
        "dialogue_stagnation_limit": 2,
        "transfer_tolerance": 0,
        "constraint_miss_limit": 1,
        "max_turn_elapsed_sec": 5.0
      },
      {
        "pipeline_pressure_profile_key": "asr_degradation",
        "profile_key": "P3-asr-degradation",
        "pressure_strategy": "asr_degradation",
        "expected_outcome_band": "semi_successful_or_unsuccessful",
        "agent_a_audio_persona": "neutral_caller",
        "agent_b_audio_persona": "brisk_operator",
        "speech_pattern_key": "mostly_clean",
        "asr_beam_size": 1,
        "asr_domain_normalization_enabled": false,
        "asr_domain_similarity_threshold": 0.98,
        "channel_noise_snr_db": 20.0,
        "channel_gain_db": -5.0,
        "channel_clip_threshold": 0.82,
        "channel_dropout_rate": 0.03,
        "num_turns": 12,
        "dialogue_stagnation_limit": 2,
        "transfer_tolerance": 1,
        "max_turn_elapsed_sec": 5.0
      },
      {
        "pipeline_pressure_profile_key": "audio_persona_ladder",
        "profile_key": "P4-audio-persona",
        "pressure_strategy": "audio_persona_ladder",
        "expected_outcome_band": "semi_successful_or_unsuccessful",
        "agent_a_audio_persona": "barely_understandable_caller",
        "agent_b_audio_persona": "degraded_operator",
        "speech_pattern_key": "stutter_heavy",
        "asr_beam_size": 6,
        "asr_domain_normalization_enabled": true,
        "asr_domain_similarity_threshold": 0.94,
        "channel_noise_snr_db": 12.0,
        "channel_gain_db": -8.0,
        "channel_clip_threshold": 0.55,
        "channel_dropout_rate": 0.07,
        "num_turns": 14,
        "dialogue_stagnation_limit": 2,
        "transfer_tolerance": 1,
        "max_turn_elapsed_sec": 5.0
      },
      {
        "pipeline_pressure_profile_key": "turn_budget_ladder",
        "profile_key": "P5-turn-budget",
        "pressure_strategy": "turn_budget_ladder",
        "expected_outcome_band": "unsuccessful",
        "agent_a_audio_persona": "degraded_caller",
        "agent_b_audio_persona": "brisk_operator",
        "speech_pattern_key": "severe_channel",
        "asr_beam_size": 1,
        "asr_domain_normalization_enabled": false,
        "asr_domain_similarity_threshold": 0.98,
        "channel_noise_snr_db": 8.0,
        "channel_gain_db": -10.0,
        "channel_clip_threshold": 0.45,
        "channel_dropout_rate": 0.12,
        "num_turns": 8,
        "dialogue_stagnation_limit": 1,
        "transfer_tolerance": 0,
        "constraint_miss_limit": 1,
        "max_turn_elapsed_sec": 4.0
      }
    ]
  },
  "parameter_values": {
    "matrix_family": ["userlm_pressure_grid_v1"],
    "experiment_platform": ["linux"],
    "network_seed": [42, 77, 123],
    "asr_beam_size": [16],
    "dialogue_stagnation_limit": [2],
    "transfer_tolerance": [1],
    "minimum_stage_suboptimal_options": [2]
  }
}
