{
  "schema_version": 1,
  "name": "tinyllama_piper_faster_whisper_comparison",
  "description": "Pairwise two-scenario matrix for TinyLlama agents, Piper synthesis, and Faster-Whisper recognition. It covers every speech-pattern, operator-audio-persona, synthesis-profile, and search-width pair with matched text controls.",
  "coverage_strategy": "pairwise",
  "iterations": 2,
  "config": {
    "agent_a_type": "tinyllama",
    "agent_b_plugin": "llm",
    "model_profile": "tinyllama_1b_transformers",
    "model_provider": "transformers",
    "model_name": "TinyLlama/TinyLlama-1.1B-Chat-v1.0",
    "allow_model_download": false,
    "num_turns": 20,
    "maximum_progressive_constraints": 3,
    "minimum_compared_routes": 2,
    "paired_audio_text_runs": true,
    "speech_playback_enabled": false,
    "speech_realtime_enabled": false,
    "tts_engine": "piper",
    "asr_engine": "faster_whisper",
    "tts_model": ".speech-providers/models/piper/en_US-lessac-medium.onnx",
    "asr_model": ".speech-providers/models/faster-whisper",
    "asr_device": "cpu",
    "log_profile": "full"
  },
  "grid": {
    "test_cases": ["morning_peak_cross_city", "midday_transfer"],
    "personas": ["focused_commuter"],
    "agent_a_audio_personas": ["high_clarity_caller"],
    "agent_b_audio_personas": [
      "clear_operator",
      "high_clarity_operator",
      "brisk_operator",
      "reassuring_operator",
      "deliberate_operator",
      "degraded_operator",
      "barely_understandable_operator"
    ],
    "speech_patterns": [
      "clean",
      "mostly_clean",
      "hesitant",
      "long_pauses",
      "stutter_light",
      "stutter_heavy",
      "filler_words",
      "compressed",
      "noisy_station",
      "clipped_words",
      "misheard_station"
    ],
    "model_params": ["greedy"],
    "objective_modes": ["shortest_valid_route_with_constraints"],
    "tts_engines": ["piper"],
    "asr_engines": ["faster_whisper"],
    "agent_b_models": ["TinyLlama/TinyLlama-1.1B-Chat-v1.0"]
  },
  "parameter_values": {
    "asr_beam_size": [1, 6, 11, 16]
  },
  "parameter_profiles": [
    {
      "profile_key": "baseline",
      "agent_a_custom_audio": true,
      "agent_b_custom_audio": true,
      "agent_a_speed": 1.0,
      "agent_b_speed": 1.0,
      "agent_a_temperature": 0.15,
      "agent_b_temperature": 0.15,
      "agent_a_top_p": 0.5,
      "agent_b_top_p": 0.5,
      "asr_compute_type": "int8"
    },
    {
      "profile_key": "fast_speech",
      "agent_a_custom_audio": true,
      "agent_b_custom_audio": true,
      "agent_a_speed": 1.18,
      "agent_b_speed": 1.18,
      "agent_a_temperature": 0.15,
      "agent_b_temperature": 0.15,
      "agent_a_top_p": 0.5,
      "agent_b_top_p": 0.5,
      "asr_compute_type": "int8"
    },
    {
      "profile_key": "acoustic_variation",
      "agent_a_custom_audio": true,
      "agent_b_custom_audio": true,
      "agent_a_speed": 1.0,
      "agent_b_speed": 1.0,
      "agent_a_temperature": 0.35,
      "agent_b_temperature": 0.35,
      "agent_a_top_p": 0.75,
      "agent_b_top_p": 0.75,
      "asr_compute_type": "int8"
    },
    {
      "profile_key": "slow_clear_speech",
      "agent_a_custom_audio": true,
      "agent_b_custom_audio": true,
      "agent_a_speed": 0.9,
      "agent_b_speed": 0.9,
      "agent_a_temperature": 0.15,
      "agent_b_temperature": 0.15,
      "agent_a_top_p": 0.5,
      "agent_b_top_p": 0.5,
      "asr_compute_type": "int8"
    }
  ]
}
